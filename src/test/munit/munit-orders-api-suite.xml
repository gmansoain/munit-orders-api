        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 50">
                <munit:payload value="#[output application/json --- {amount: 50}]" mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when doc:name="Mock post-alert (defence)" processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[output application/json --- {}]" mediaType="application/json"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: the entry flow runs -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: record survives; accepted + notified=false; no call -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert status == accepted"
                                     expression="#[payload.status]"
                                     is="#[MunitTools::equalTo('accepted')]"/>
            <munit-tools:assert-that doc:name="Assert notified == false"
                                     expression="#[payload.notified]"
                                     is="#[MunitTools::equalTo(false)]"/>
            <munit-tools:assert-that doc:name="Assert tier == standard"
                                     expression="#[payload.tier]"
                                     is="#[MunitTools::equalTo('standard')]"/>
            <munit-tools:assert-that doc:name="Assert amount == 50"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(50)]"/>
            <munit-tools:verify-call doc:name="Verify post-alert never called" processor="http:request" times="0">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <munit:test name="orders-api-main-should-propagate-invalid-when-amount-not-positive"
                description="An invalid amount propagates ORDERS:INVALID (mapped to HTTP 400 by the listener; status code not observable here — OQ-1)."
                tags="error,regression"
                expectedErrorType="ORDERS:INVALID">
        <!-- GIVEN: an invalid order -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 0">
                <munit:payload value="#[output application/json --- {amount: 0}]" mediaType="application/json"/>
            </munit:set-event>
        </munit:behavior>
        <!-- WHEN: the entry flow runs (on-error-propagate re-raises) -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: error asserted via expectedErrorType; validation empty (handler re-raises) -->
        <munit:validation/>
    </munit:test>

    <munit:test name="orders-api-main-should-accept-order-with-notified-false-when-notification-fails"
                description="When the notification call fails the order is still accepted with notified=false; the record survives and no status field is added (observed behaviour, OQ-2)."
                tags="error,regression">
        <!-- GIVEN: a large order, post-alert raises a connectivity error -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when doc:name="Mock post-alert raises HTTP:CONNECTIVITY" processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:error typeId="HTTP:CONNECTIVITY"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: the entry flow runs (on-error-continue catches HTTP:CONNECTIVITY) -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: order record survives (failed call did not overwrite payload); notified=false; no status -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert notified == false"
                                     expression="#[payload.notified]"
                                     is="#[MunitTools::equalTo(false)]"/>
            <munit-tools:assert-that doc:name="Assert amount == 250"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(250)]"/>
            <munit-tools:assert-that doc:name="Assert tier == priority"
                                     expression="#[payload.tier]"
                                     is="#[MunitTools::equalTo('priority')]"/>
            <munit-tools:assert-that doc:name="Assert no status field added"
                                     expression="#[payload.status]"
                                     is="#[MunitTools::nullValue()]"/>
        </munit:validation>
    </munit:test>

