    <!-- ============================================================ -->
    <!-- notify-flow  (integration / connector, one http:request)     -->
    <!-- ============================================================ -->

    <munit:test name="notify-should-call-post-alert-and-return-its-response"
                description="The notify flow calls post-alert exactly once and returns its response body."
                tags="smoke,regression">
        <!-- GIVEN: post-alert returns a 200 body -->
        <munit:behavior>
            <munit:set-event doc:name="Input: any order payload">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when doc:name="Mock post-alert returns {ok:true}" processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[output application/json --- {ok: true}]" mediaType="application/json"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: notify runs -->
        <munit:execution>
            <flow-ref name="notify-flow"/>
        </munit:execution>
        <!-- THEN: response body returned and post-alert called once -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert response ok == true"
                                     expression="#[payload.ok]"
                                     is="#[MunitTools::equalTo(true)]"/>
            <munit-tools:verify-call doc:name="Verify post-alert called once" processor="http:request" times="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <munit:test name="notify-should-return-empty-body-when-alert-returns-empty"
                description="The notify flow returns an empty body when post-alert responds with an empty object."
                tags="regression">
