    <munit:test name="notify-should-propagate-when-post-alert-connectivity-fails"
                description="The notify flow propagates HTTP:CONNECTIVITY when post-alert fails (no local handler)."
                tags="error,regression"
                expectedErrorType="HTTP:CONNECTIVITY">
        <!-- GIVEN: post-alert raises a connectivity error -->
        <munit:behavior>
            <munit:set-event doc:name="Input: any order payload">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when doc:name="Mock post-alert raises HTTP:CONNECTIVITY" processor="http:request">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:error typeId="HTTP:CONNECTIVITY"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: notify runs (aborts at the failing call) -->
        <munit:execution>
            <flow-ref name="notify-flow"/>
        </munit:execution>
        <!-- THEN: error asserted via expectedErrorType -->
        <munit:validation/>
    </munit:test>

