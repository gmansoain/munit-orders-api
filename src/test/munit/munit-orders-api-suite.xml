                    <munit-tools:payload value="#[output application/json --- {}]" mediaType="application/json"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: routing runs -->
        <munit:execution>
            <flow-ref name="route-order-flow"/>
        </munit:execution>
        <!-- THEN: status/notified survive (post-alert return overwrote the record); call made once -->
        <munit:validation>
