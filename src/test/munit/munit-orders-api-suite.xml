<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  Suite:        munit-orders-api-suite
  Unit(s):      orders-api-main             (API entry flow + error handler)
                validate-order-subflow      (choice / router; raises ORDERS:INVALID)
                build-order-record-subflow  (transformation, pure DataWeave)
                route-order-flow            (orchestration + choice)
                notify-flow                 (integration / connector, one http:request)
  Source:       src/main/mule/munit-orders-api.xml
  Purpose:      Unit-test order validation, record building, threshold routing,
                notification, and the entry-flow error handling (offline, mocked).
  Collaborators mocked: http:request (post-alert)
  Tags:         smoke, regression, error
  Coverage:     all 5 flows + every choice branch + both handled error paths
                (100% application coverage, 16/16 processors — reports/munit-orders-api-report.html)
  Tests:        20 (munit:test)
  Last reviewed: 2026-06-30  (Gonzalo Marcos — documentation pass, no test logic changed)
  ============================================================
-->
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core
          http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/munit
          http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
        http://www.mulesoft.org/schema/mule/munit-tools
          http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

    <munit:config name="munit-orders-api-suite" minMuleVersion="4.9.11" doc:name="Orders API unit suite"/>

    <!-- ============================================================ -->
    <!-- validate-order-subflow  (choice / router; raises ORDERS:INVALID) -->
    <!-- ============================================================ -->

    <munit:test name="validate-order-should-pass-when-amount-positive"
                description="A positive amount passes validation and the payload is left unchanged."
                tags="smoke,regression">
        <!-- GIVEN: a valid order -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
        </munit:behavior>
        <!-- WHEN: validation runs -->
        <munit:execution>
            <flow-ref name="validate-order-subflow"/>
        </munit:execution>
        <!-- THEN: no error and the amount survives -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert amount == 250"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(250)]"/>
        </munit:validation>
    </munit:test>

    <munit:test name="validate-order-should-raise-invalid-when-amount-zero"
                description="An amount of zero is rejected with ORDERS:INVALID."
                tags="error,regression"
                expectedErrorType="ORDERS:INVALID">
        <!-- GIVEN: amount at the <= 0 boundary -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 0">
                <munit:payload value="#[output application/json --- {amount: 0}]" mediaType="application/json"/>
            </munit:set-event>
        </munit:behavior>
        <!-- WHEN: validation runs (aborts at raise-error) -->
        <munit:execution>
            <flow-ref name="validate-order-subflow"/>
        </munit:execution>
        <!-- THEN: error asserted via expectedErrorType; validation block empty -->
        <munit:validation/>
    </munit:test>

    <munit:test name="validate-order-should-raise-invalid-when-amount-negative"
                description="A negative amount is rejected with ORDERS:INVALID."
                tags="error,regression"
