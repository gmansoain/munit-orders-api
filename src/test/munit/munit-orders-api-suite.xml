    <munit:test name="build-order-record-should-set-priority-tier-when-amount-over-100"
                description="An amount over 100 builds a record with tier=priority and echoes the amount and an orderId."
                tags="smoke,regression">
        <!-- GIVEN: a large order -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
        </munit:behavior>
        <!-- WHEN: the record is built -->
        <munit:execution>
            <flow-ref name="build-order-record-subflow"/>
        </munit:execution>
        <!-- THEN: priority tier, amount echoed, orderId present (uuid -> matcher) -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert tier == priority"
                                     expression="#[payload.tier]"
                                     is="#[MunitTools::equalTo('priority')]"/>
            <munit-tools:assert-that doc:name="Assert amount == 250"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(250)]"/>
            <munit-tools:assert-that doc:name="Assert orderId is present"
                                     expression="#[payload.orderId]"
                                     is="#[MunitTools::notNullValue()]"/>
        </munit:validation>
