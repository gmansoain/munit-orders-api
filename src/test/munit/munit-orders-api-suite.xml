        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[output application/json --- {amount: 250}]" mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when doc:name="Mock post-alert returns 200" processor="http:request">
                <munit-tools:with-attributes>
