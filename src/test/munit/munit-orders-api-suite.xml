<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  Suite:        munit-orders-api-suite
  Unit(s):      orders-api-main             (API entry flow + error handler)
                validate-order-subflow      (choice / router, raises ORDERS:INVALID)
                build-order-record-subflow  (transformation)
                route-order-flow            (orchestration + choice)
                notify-flow                 (integration / connector)
  Source:       src/main/mule/munit-orders-api.xml
  Purpose:      Verify order validation, record shaping, threshold-based notification
                routing, and the entry-flow error handling (ORDERS:INVALID, HTTP:CONNECTIVITY).
  Collaborators mocked: http:request (post-alert)
  Tags:         smoke, regression, error
  Coverage:     all 5 units — happy, branch, boundary, negative, and error paths
  Last reviewed: 2026-06-29  (MUnit test-generation agent)

  NOTE on parameterization: MUnit 3.6 declares <munit:parameterizations> under <munit:config>
  (suite-scoped — the whole suite re-runs per parameterization). That is incompatible with the
  two independent data sets in this suite plus the non-parameterized tests, so the two designed
  parameterized tests are implemented as explicit per-case tests (identical coverage).
  ============================================================
-->
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core
          http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/munit
          http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
        http://www.mulesoft.org/schema/mule/munit-tools
          http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

    <munit:config name="munit-orders-api-suite" minMuleVersion="4.9.0"/>

    <!-- ============================================================
         Unit: orders-api-main  (API entry flow + error handler)
         ============================================================ -->

    <munit:test name="orders-api-main-should-accept-and-notify-large-order"
                description="A valid order with amount greater than 100 is accepted, triggers exactly one notification, and is marked notified=true."
                tags="smoke,regression">
        <!-- GIVEN: a valid large order; the alert call succeeds -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[%dw 2.0 output application/json --- { amount: 250 }]"
                               mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when processor="http:request" doc:name="Mock post-alert returns 200">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[%dw 2.0 output application/json --- { delivered: true }]"
                                         mediaType="application/json"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: the entry flow runs -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: accepted + notified, alert called once.
             NOTE: orderId/amount/tier are NOT asserted here — notify-flow's http:request
             replaces the payload with the (mocked) HTTP response on the success branch. -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert status == accepted"
                                     expression="#[payload.status]"
                                     is="#[MunitTools::equalTo('accepted')]"/>
            <munit-tools:assert-that doc:name="Assert notified == true"
                                     expression="#[payload.notified]"
                                     is="#[MunitTools::equalTo(true)]"/>
            <munit-tools:verify-call doc:name="Verify post-alert called once" processor="http:request" times="1">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <munit:test name="orders-api-main-should-accept-small-order-without-notifying"
                description="A valid order with amount not greater than 100 is accepted without calling the notification, and is marked notified=false."
                tags="smoke,regression">
        <!-- GIVEN: a valid boundary order (100); alert mocked as defence -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 100">
                <munit:payload value="#[%dw 2.0 output application/json --- { amount: 100 }]"
                               mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when processor="http:request" doc:name="Mock post-alert (defence, must not be called)">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:payload value="#[%dw 2.0 output application/json --- { delivered: true }]"
                                         mediaType="application/json"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: the entry flow runs -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: accepted + not notified; record survives (no notify on this branch) -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert status == accepted"
                                     expression="#[payload.status]"
                                     is="#[MunitTools::equalTo('accepted')]"/>
            <munit-tools:assert-that doc:name="Assert notified == false"
                                     expression="#[payload.notified]"
                                     is="#[MunitTools::equalTo(false)]"/>
            <munit-tools:assert-that doc:name="Assert tier == standard"
                                     expression="#[payload.tier]"
                                     is="#[MunitTools::equalTo('standard')]"/>
            <munit-tools:assert-that doc:name="Assert amount preserved == 100"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(100)]"/>
            <munit-tools:verify-call doc:name="Verify post-alert never called" processor="http:request" times="0">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
            </munit-tools:verify-call>
        </munit:validation>
    </munit:test>

    <munit:test name="orders-api-main-should-propagate-invalid-order-as-orders-invalid"
                description="An order with a non-positive amount fails the entry flow by propagating ORDERS:INVALID."
                expectedErrorType="ORDERS:INVALID"
                tags="error,regression">
        <!-- GIVEN: an invalid order (amount 0) -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 0">
                <munit:payload value="#[%dw 2.0 output application/json --- { amount: 0 }]"
                               mediaType="application/json"/>
            </munit:set-event>
        </munit:behavior>
        <!-- WHEN: the entry flow runs -->
        <!-- THEN: ORDERS:INVALID is re-raised (on-error-propagate) — asserted via expectedErrorType -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
    </munit:test>

    <munit:test name="orders-api-main-should-accept-order-when-notification-fails"
                description="When the notification call fails with HTTP:CONNECTIVITY, the order is still accepted and marked notified=false; no status field is set."
                tags="error,regression">
        <!-- GIVEN: a valid large order; the alert call raises a connectivity error -->
        <munit:behavior>
            <munit:set-event doc:name="Input: order amount 250">
                <munit:payload value="#[%dw 2.0 output application/json --- { amount: 250 }]"
                               mediaType="application/json"/>
            </munit:set-event>
            <munit-tools:mock-when processor="http:request" doc:name="Mock post-alert raises HTTP:CONNECTIVITY">
                <munit-tools:with-attributes>
                    <munit-tools:with-attribute attributeName="doc:name" whereValue="post-alert"/>
                </munit-tools:with-attributes>
                <munit-tools:then-return>
                    <munit-tools:error typeId="HTTP:CONNECTIVITY"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
        </munit:behavior>
        <!-- WHEN: the entry flow runs -->
        <munit:execution>
            <flow-ref name="orders-api-main"/>
        </munit:execution>
        <!-- THEN: order recovered, notified=false, record preserved (request failed before replacing payload), status absent -->
        <munit:validation>
            <munit-tools:assert-that doc:name="Assert notified == false"
                                     expression="#[payload.notified]"
                                     is="#[MunitTools::equalTo(false)]"/>
            <munit-tools:assert-that doc:name="Assert amount preserved == 250"
                                     expression="#[payload.amount]"
                                     is="#[MunitTools::equalTo(250)]"/>
            <munit-tools:assert-that doc:name="Assert tier == priority"
                                     expression="#[payload.tier]"
                                     is="#[MunitTools::equalTo('priority')]"/>
            <munit-tools:assert-that doc:name="Assert orderId is present"
                                     expression="#[payload.orderId]"
                                     is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that doc:name="Assert status is absent"
                                     expression="#[payload.status]"
                                     is="#[MunitTools::nullValue()]"/>
        </munit:validation>
    </munit:test>

